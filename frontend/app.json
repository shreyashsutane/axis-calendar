{
  "expo": {
    "name": "Axis Bank Training Calendar",
    "slug": "axis-bank-training-calendar",
    "version": "1.0.0",
    "orientation": "portrait",
    "userInterfaceStyle": "automatic",
    "assetBundlePatterns": [
      "**/*"
    ],
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.axisbank.trainingcalendar"
    },
    "android": {
      "package": "com.axisbank.trainingcalendar"
    },
    "plugins": [
      "expo-router",
      "expo-notifications"
    ],
    "scheme": "axistrainingcalendar"
  }
}
